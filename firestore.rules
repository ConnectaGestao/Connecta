rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Função auxiliar: Verifica se o usuário está logado com uma conta Google válida no app
    function isAuth() {
      return request.auth != null;
    }
    
    // -------------------------------------------------------------------------
    // COLEÇÕES DO SISTEMA "NOVA GESTÃO CENTRAL"
    // -------------------------------------------------------------------------
    match /pacientes/{pacienteId} {
      // Qualquer pessoa autenticada na sua equipe pode ler, criar e alterar fichas
      allow read, create, update: if isAuth();
      // Opcional: Para blindagem máxima contra exclusões acidentais de hackers,
      // você pode trocar para "allow delete: if false;" se preferir que apenas o dono do Firebase 
      // possa deletar direto pelo console. Mas deixaremos ativado para usuários logados por enquanto.
      allow delete: if isAuth(); 
    }
    
    match /atendimentos/{atendimentoId} {
      allow read, create, update, delete: if isAuth();
    }
    
    match /parceiros/{parceiroId} {
      allow read, create, update, delete: if isAuth();
    }
    
    match /agenda/{agendaId} {
      allow read, create, update, delete: if isAuth();
    }
    
    // IMPORTANTE: Permite que o sistema leia a role do usuário no login
    match /usuarios/{usuarioId} {
      allow read, create, update: if isAuth();
    }
    
    match /filtros/{filtroId} {
      allow read, create, update, delete: if isAuth();
    }
    // Regra padrão bloqueando qualquer outra coleção desconhecida
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
